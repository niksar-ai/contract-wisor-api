<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Spring Boot's default conversion rules, colors, and CONSOLE/FILE log patterns -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Log directory; override with -DLOG_DIR=/some/path or env LOG_DIR -->
    <property name="LOG_DIR" value="${LOG_DIR:-logs}"/>

    <!-- Rolling file: rotate daily and at 20MB, keep 14 days, cap total at 500MB -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/contract-wisor-api.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/contract-wisor-api.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Our own code: keep verbose so business-logic flow and errors are visible -->
    <logger name="ai.niksar" level="DEBUG"/>

    <!-- Framework noise: turn the firehose down to INFO -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.hibernate" level="INFO"/>
    <logger name="org.hibernate.SQL" level="INFO"/>
    <logger name="org.hibernate.orm.jdbc.bind" level="INFO"/>
    <logger name="com.zaxxer.hikari" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
