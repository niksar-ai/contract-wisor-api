# Copy to .env (or export as real environment variables) and fill in.
# These override the safe localhost defaults baked into application.properties.
# Never commit a filled-in .env — it is gitignored.

# --- Database (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/contractwisor
DB_USERNAME=contractwisor
DB_PASSWORD=

# --- JWT signing secrets (Base64-encoded; generate fresh, do not reuse) ---
# e.g. openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- SFTP ---
SFTP_SECRET=

# --- Temporal ---
TEMPORAL_TARGET=localhost:7233

# --- External AI / parse services ---
CWAI_API_TARGET=http://localhost:8000
PARSE_DOCUMENT_API=http://localhost:8000/api/parseDocument

# --- Web / CORS ---
WEB_DOMAIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Mail ---
MAIL_HOST=localhost
MAIL_PORT=1025
COMPANY_MAIL_NOREPLY=noreply@example.com
COMPANY_MAIL_INFO=info@example.com
